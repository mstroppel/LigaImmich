# Example environment for running the LigaImmich worker in Docker.
# Copy to `.env` and adjust. Use with `docker run --env-file .env ...`.

# --- Immich API connection (required) ---
IMMICH_BASE_URL=https://immich.example.com/api
IMMICH_API_KEY=replace-me

# --- Scheduler (optional; shown with defaults) ---
# SCHEDULER_TIMEZONE=Europe/Berlin
# SCHEDULER_SYNC_ALBUMS_CRON=0 */1 * * * *
# SCHEDULER_SYNC_ALBUMS_ENABLED=true
