# Example environment for running the LigaImmich worker in Docker.
# Copy to `.env` and adjust. Use with `docker run --env-file .env ...`.
#
# Settings follow .NET's double-underscore convention: `Section__Key`.

# --- Immich API connection (required) ---
Immich__BaseUrl=https://immich.example.com/api
Immich__ApiKey=replace-me

# --- Scheduler (optional; shown with defaults) ---
# Scheduler__TimeZone=Europe/Berlin
# Scheduler__Tasks__SyncAlbums__Cron=0 */1 * * * *
# Scheduler__Tasks__SyncAlbums__Enabled=true
